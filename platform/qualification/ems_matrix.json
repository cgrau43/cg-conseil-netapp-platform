{
  "version": "1.0",
  "client": "twentytwo",
  "rules": [
    {
      "pattern": "snapvault.truncated",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Relation SnapVault tronquée — vérifier la cohérence du backup"
    },
    {
      "pattern": "snapvault.lag.warn",
      "severity": "WARNING",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Délai réplication SnapVault dépassant le seuil d'avertissement"
    },
    {
      "pattern": "snapvault.lag.err",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Délai réplication SnapVault critique — SLA backup en risque"
    },
    {
      "pattern": "snapvault.dst.snap.miss",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Snapshot SnapVault manquant sur la destination — backup incomplet"
    },
    {
      "pattern": "snapvault.src.snap.miss",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Snapshot SnapVault manquant sur la source — backup SnapCenter en échec"
    },
    {
      "pattern": "snapvault.transfer.fail",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Transfert SnapVault en échec — vérifier la connectivité inter-cluster"
    },
    {
      "pattern": "sc.backup.fail",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Backup SnapCenter en échec — intervention requise"
    },
    {
      "pattern": "sc.restore.fail",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Restauration SnapCenter en échec — PRA compromis"
    },
    {
      "pattern": "snapmgr.snapshot.missed",
      "severity": "ERROR",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Snapshot planifié manquant — politique de protection non respectée"
    },
    {
      "pattern": "snapmgr.vol.nosnap",
      "severity": "WARNING",
      "category": "backup",
      "jira_request_type": "JIRA_REQUEST_TYPE_BACKUP",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Volume sans snapshot depuis trop longtemps — vérifier la planification"
    },
    {
      "pattern": "snapmirror.transfer.fail",
      "severity": "ERROR",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Transfert SnapMirror en échec — réplication PRA interrompue"
    },
    {
      "pattern": "snapmirror.lag.warn",
      "severity": "WARNING",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Délai SnapMirror dépassant le seuil — RPO en risque"
    },
    {
      "pattern": "snapmirror.lag.err",
      "severity": "ERROR",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Délai SnapMirror critique — RPO non respecté, PRA dégradé"
    },
    {
      "pattern": "snapmirror.state.change",
      "severity": "WARNING",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Changement d'état SnapMirror — vérifier la relation de réplication"
    },
    {
      "pattern": "snapmirror.dst.quiesced",
      "severity": "WARNING",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Relation SnapMirror mise en pause — opération planifiée ou manuelle"
    },
    {
      "pattern": "snapmirror.broken.off",
      "severity": "ALERT",
      "category": "snapmirror",
      "jira_request_type": "JIRA_REQUEST_TYPE_PRA",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Relation SnapMirror rompue (broken-off) — basculement PRA en cours ou erreur critique"
    },
    {
      "pattern": "monitor.volume.full",
      "severity": "EMERGENCY",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Volume plein à 100% — risque d'indisponibilité des données immédiat"
    },
    {
      "pattern": "monitor.volume.nearlyFull",
      "severity": "ERROR",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Volume presque plein (>95%) — extension ou nettoyage requis rapidement"
    },
    {
      "pattern": "monitor.vol.autosize.done",
      "severity": "WARNING",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "update_ticket",
      "priority": "medium",
      "message_fr": "Autosize déclenché sur le volume — surveiller la croissance des données"
    },
    {
      "pattern": "wafl.vol.autosize.fail",
      "severity": "ERROR",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Échec de l'autosize — le volume ne peut pas s'agrandir automatiquement"
    },
    {
      "pattern": "monitor.aggr.nearlyFull",
      "severity": "ERROR",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Agrégat presque plein (>90%) — ajouter des disques ou déplacer des volumes"
    },
    {
      "pattern": "monitor.aggr.full",
      "severity": "EMERGENCY",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Agrégat plein — aucune écriture possible, intervention immédiate requise"
    },
    {
      "pattern": "quota.exceeded",
      "severity": "WARNING",
      "category": "capacite",
      "jira_request_type": "JIRA_REQUEST_TYPE_CAPACITE",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Quota dépassé sur un volume ou qtree — vérifier les politiques de quota"
    },
    {
      "pattern": "dns.timeout",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Timeout DNS — résolution de nom impossible, vérifier les serveurs DNS configurés"
    },
    {
      "pattern": "dns.lookup.fail",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Échec résolution DNS — impact possible sur SnapMirror, CIFS, LDAP"
    },
    {
      "pattern": "net.tcp.badChecksum",
      "severity": "WARNING",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "medium",
      "message_fr": "Mauvais checksum TCP détecté — possible problème NIC, câble ou switch"
    },
    {
      "pattern": "net.tcp.badChecksum.high",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Taux élevé de checksum TCP incorrects — instabilité réseau critique"
    },
    {
      "pattern": "net.if.linkDown",
      "severity": "ALERT",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Interface réseau DOWN — basculement sur port partenaire si disponible"
    },
    {
      "pattern": "net.if.linkUp",
      "severity": "WARNING",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Interface réseau revenue UP — vérifier la stabilité (flapping)"
    },
    {
      "pattern": "net.port.flapping",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Port réseau en flapping — instabilité détectée, vérifier le câblage et le switch"
    },
    {
      "pattern": "lif.migrate",
      "severity": "WARNING",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "update_ticket",
      "priority": "medium",
      "message_fr": "Migration de LIF détectée — vérifier si planifiée ou suite à un incident réseau"
    },
    {
      "pattern": "lif.migrate.fail",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Échec migration de LIF — accès client potentiellement impacté"
    },
    {
      "pattern": "disk.sectorError",
      "severity": "ERROR",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Erreur de secteur disque — risque perte données, remplacement préventif conseillé"
    },
    {
      "pattern": "disk.failure",
      "severity": "EMERGENCY",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Disque en panne — reconstruction RAID en cours, intervention requise"
    },
    {
      "pattern": "disk.predictive.failure",
      "severity": "ALERT",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Défaillance disque prévisible (SMART) — planifier le remplacement préventif"
    },
    {
      "pattern": "raid.rg.recons.percent",
      "severity": "WARNING",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "update_ticket",
      "priority": "medium",
      "message_fr": "Reconstruction RAID en cours — surveiller progression, éviter E/S intensives"
    },
    {
      "pattern": "raid.rg.recons.done",
      "severity": "WARNING",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Reconstruction RAID terminée — vérifier l'intégrité de l'agrégat"
    },
    {
      "pattern": "raid.rg.bad.summ",
      "severity": "EMERGENCY",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Erreur RAID critique (double panne) — risque de perte de données immédiat"
    },
    {
      "pattern": "disk.timeout",
      "severity": "ERROR",
      "category": "disque",
      "jira_request_type": "JIRA_REQUEST_TYPE_DISQUE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Timeout disque — possible problème chemin SAN ou défaillance imminente"
    },
    {
      "pattern": "fci.port.linkDown",
      "severity": "ALERT",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_SAN",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Port Fibre Channel DOWN — vérifier le câblage et le switch FC"
    },
    {
      "pattern": "fci.port.linkUp",
      "severity": "WARNING",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_SAN",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Port Fibre Channel revenu UP — vérifier la stabilité"
    },
    {
      "pattern": "san.lun.offline",
      "severity": "EMERGENCY",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_SAN",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "LUN hors ligne — VM ou serveur potentiellement impacté, intervention immédiate"
    },
    {
      "pattern": "san.lun.online",
      "severity": "WARNING",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_SAN",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "LUN revenue en ligne — vérifier l'accès côté hôte"
    },
    {
      "pattern": "iscsi.connection.drop",
      "severity": "ERROR",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_SAN",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Connexion iSCSI interrompue — vérifier réseau stockage et initiateur"
    },
    {
      "pattern": "audit.log.full",
      "severity": "ERROR",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_SECURITE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Journal d'audit plein — les événements de sécurité ne sont plus enregistrés"
    },
    {
      "pattern": "fpolicy.server.disconnect",
      "severity": "ERROR",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_SECURITE",
      "action": "create_ticket",
      "priority": "high",
      "message_fr": "Serveur FPolicy déconnecté — protection antivirus/ransomware inactive"
    },
    {
      "pattern": "fpolicy.server.connect",
      "severity": "WARNING",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_SECURITE",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Serveur FPolicy reconnecté — protection restaurée"
    },
    {
      "pattern": "callhome.hainterconnect.down",
      "severity": "EMERGENCY",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_HA",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Interconnexion HA DOWN — risque de split-brain, intervention immédiate requise"
    },
    {
      "pattern": "callhome.reboot.unknown",
      "severity": "ALERT",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_SECURITE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Redémarrage inattendu du nœud — analyser la cause (panique, coupure alimentation)"
    },
    {
      "pattern": "callhome.panic",
      "severity": "EMERGENCY",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_SECURITE",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Panique ONTAP détectée — collecte core dump et analyse requises immédiatement"
    },
    {
      "pattern": "cf.takeover.started",
      "severity": "ALERT",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_HA",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Takeover HA démarré — vérifier la cause (panne nœud ou maintenance)"
    },
    {
      "pattern": "cf.giveback.started",
      "severity": "WARNING",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_HA",
      "action": "update_ticket",
      "priority": "medium",
      "message_fr": "Giveback HA démarré — retour à la configuration normale en cours"
    },
    {
      "pattern": "cf.giveback.done",
      "severity": "WARNING",
      "category": "securite",
      "jira_request_type": "JIRA_REQUEST_TYPE_HA",
      "action": "update_ticket",
      "priority": "low",
      "message_fr": "Giveback HA terminé — cluster revenu en configuration normale"
    },
    {
      "pattern": "cluster.switch.linkDown",
      "severity": "ALERT",
      "category": "reseau",
      "jira_request_type": "JIRA_REQUEST_TYPE_RESEAU",
      "action": "create_ticket",
      "priority": "highest",
      "message_fr": "Lien cluster switch DOWN — communication inter-nœuds dégradée"
    },
    {
      "pattern": "monitor.temp.ok",
      "severity": "WARNING",
      "category": "securite",
      "jira_request_type": null,
      "action": "ignore",
      "priority": "low",
      "message_fr": "Température revenue à la normale — aucune action requise"
    },
    {
      "pattern": "monitor.fan.ok",
      "severity": "WARNING",
      "category": "securite",
      "jira_request_type": null,
      "action": "ignore",
      "priority": "low",
      "message_fr": "Ventilateur revenu à la normale — aucune action requise"
    },
    {
      "pattern": "scsiblade.sas.port.stable",
      "severity": "WARNING",
      "category": "disque",
      "jira_request_type": null,
      "action": "ignore",
      "priority": "low",
      "message_fr": "Port SAS stable — événement informatif, aucune action requise"
    }
  ]
}