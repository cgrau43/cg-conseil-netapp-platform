# ============================================================
# CG CONSEIL — Plateforme MCO NetApp
# Fichier d'exemple des variables d'environnement
# Copier en .env et renseigner les valeurs réelles
# NE JAMAIS COMMITTER le fichier .env (voir .gitignore)
# ============================================================

# ---- Claude / Anthropic ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# ---- ONTAP REST API ----
ONTAP_CLUSTER_URL=https://cluster.local
ONTAP_USERNAME=admin
ONTAP_PASSWORD=

# ---- SnapCenter ----
SNAPCENTER_URL=https://snapcenter.local
SNAPCENTER_TOKEN=

# ---- Veeam Backup & Replication ----
VEEAM_URL=https://veeam.local
VEEAM_USERNAME=admin
VEEAM_PASSWORD=

# ---- PostgreSQL ----
POSTGRES_PASSWORD=changeme_strong_password

# ---- n8n ----
N8N_USER=admin
N8N_PASSWORD=changeme_n8n_password

# ---- Notifications ----
# Destinataires des rapports (séparés par des virgules)
REPORT_RECIPIENTS=direction@exemple.fr,astreinte@exemple.fr
MANAGEMENT_EMAIL=direction@exemple.fr

# Webhook Teams ou Slack pour alertes P1/P2
WEBHOOK_TEAMS_URL=https://outlook.office.com/webhook/xxxxx
# WEBHOOK_SLACK_URL=https://hooks.slack.com/services/xxxxx

# ---- API ----
# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5678,http://localhost:3000
